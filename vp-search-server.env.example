# ═══════════════════════════════════════════════════════
# vp-search-server.env.example — VP Library Search + Embed Server
# คัดลอกไฟล์นี้เป็น vp-search-server.env แล้วใส่ค่าจริง
# ═══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...anon_key...          # ← anon key (search/read)
SUPABASE_SERVICE_KEY=eyJ...service_key...  # ← service role key (embed/write)
                                            #   Settings → API → service_role
                                            #   ถ้าไม่ใส่ จะใช้ anon key แทน

# ── mCLIP Embedding model ─────────────────────────────
EMBED_MODEL=clip-ViT-B-32-multilingual-v1

# ── LM Studio / Gemma4 (optional) ────────────────────
# ใช้เฉพาะตอนกด Embed + Tags (with_tags=true)
# ถ้าไม่ใส่ จะ embed ภาพด้วย mCLIP เท่านั้น (ไม่มี caption/tags)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma-3-27b-it          # ชื่อ model ที่โหลดใน LM Studio
LM_STUDIO_KEY=                          # Bearer token (ถ้า LM Studio ตั้ง auth ไว้)

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8766

# ── CORS ──────────────────────────────────────────────
# ใส่ domain จริงเพื่อ security เช่น:
#   CORS_ORIGINS=https://thestandard.co,https://vp.thestandard.co
# หรือ * สำหรับ development
CORS_ORIGINS=*
