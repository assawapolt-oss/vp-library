# ═══════════════════════════════════════════════════════
# vp-search-server.env.example — VP Library Search Server
# คัดลอกไฟล์นี้เป็น vp-search-server.env แล้วใส่ค่าจริง
# ═══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...anon_key...    # ← anon key พอแล้ว (read-only)

# ── mCLIP Embedding ───────────────────────────────────
# ต้องตรงกับที่ใช้ใน vp-indexer.py
EMBED_MODEL=clip-ViT-B-32-multilingual-v1

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0        # 0.0.0.0 = เปิดรับทุก IP (สำหรับ server)
PORT=8766           # port ที่ frontend เรียก

# ── CORS ──────────────────────────────────────────────
# ใส่ domain จริงเพื่อ security เช่น:
#   CORS_ORIGINS=https://thestandard.co,https://vp.thestandard.co
# หรือ * เพื่อ development (ไม่แนะนำใน production)
CORS_ORIGINS=*
