# ═══════════════════════════════════════════════════════
# vp-indexer.env.example — VP Library Scene Indexer
# คัดลอกไฟล์นี้เป็น vp-indexer.env แล้วใส่ค่าจริง
# ═══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...service_role_key...   # ← ใช้ service_role key (ไม่ใช่ anon!)

# ── LM Studio ─────────────────────────────────────────
# ตัวเลือกที่ 1: localhost (รัน indexer บน Mac เดียวกับ LM Studio)
LM_STUDIO_URL=http://localhost:1234/v1

# ตัวเลือกที่ 2: Cloudflare Tunnel (รัน indexer บนเครื่องอื่น)
# รันใน Terminal: cloudflared tunnel --url http://localhost:1234
# แล้วใส่ URL ที่ได้ เช่น:
# LM_STUDIO_URL=https://xxxx-xxxx-xxxx.trycloudflare.com/v1

LM_STUDIO_MODEL=       # เว้นว่าง = auto-detect จาก model ที่โหลดอยู่

# API Key จาก LM Studio → Developer → API Tokens (สร้างใหม่ถ้ายังไม่มี)
# ถ้าใช้ Cloudflare Tunnel ต้องใส่ key นี้ด้วย
LM_STUDIO_KEY=sk-lm-...

# ── mCLIP Embedding ───────────────────────────────────
# ต้องตรงกันระหว่าง indexer กับ search server
# อย่าเปลี่ยนถ้าไม่แน่ใจ — ต้องลบ vector เดิมและ index ใหม่ทั้งหมด
EMBED_MODEL=clip-ViT-B-32-multilingual-v1
